@tokens {
  Space { @whitespace+ }
  Name { $[A-Za-z_]+ }
  Number { $[0-9]+ }
  String { '"' !["]* '"' }
  Code { '`' (![`])* '`' }
  LBracket { "\[" }
  RBracket { "\]" }
  Comma { "," }
}

@top File { Metadata System* }

MetadataValue { Name Space String }
Metadata { (MetadataValue)* }

SystemHeader { LBracket String Comma Number RBracket }
SectionData { Name Space Code }
System { SystemHeader SectionData+ }
