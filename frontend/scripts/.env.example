# Connection settings for importTsvScores.ts (db mode).
#
# Copy this file to a per-target file and fill in the values:
#   scripts/.env.local    → your local test backend / database
#   scripts/.env.remote   → the hosting backend / remote database
#
# Select a target when running:
#   node ... ./scripts/importTsvScores.ts db --target=local
#   node ... ./scripts/importTsvScores.ts db --target=remote
# or via npm:
#   npm run import:scores:local
#   npm run import:scores:remote
#
# These .env.<target> files are git-ignored. Any variable already set in the
# shell overrides the file, so you can also override ad hoc.

# API base URL of the backend that fronts the target database.
# Local example:
TABUH_API_BASE=http://localhost:3001/api
# Remote example:
# TABUH_API_BASE=https://tabuh.studio/api

# Credentials of an editor/admin user on that backend.
TABUH_EMAIL=you@example.com
TABUH_PASSWORD=your-password
