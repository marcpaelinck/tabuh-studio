{
    "name": "tabuh-studio",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "test": "node .\\src\\scoreparsers\\grammars\\tabuh\\test.ts",
        "testnotation": "node .\\src\\scoreparsers\\grammars\\tabuh\\test\\testnotation.ts",
        "test:expand": "node --experimental-transform-types --loader ./scripts/ts_loader.mjs ./test/componentlogic/expandNotation.test.ts",
        "test:expand:generate": "node --experimental-transform-types --loader ./scripts/ts_loader.mjs ./test/componentlogic/expandNotation.test.ts --generate",
        "import:scores:file": "node --experimental-transform-types --loader ./scripts/ts_loader.mjs ./scripts/importTsvScores.ts file",
        "import:scores:local": "node --experimental-transform-types --loader ./scripts/ts_loader.mjs ./scripts/importTsvScores.ts db --target=local",
        "import:scores:remote": "node --experimental-transform-types --loader ./scripts/ts_loader.mjs ./scripts/importTsvScores.ts db --target=remote"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@lezer/generator": "^1.8.0",
        "@lezer/lr": "^1.4.2",
        "@tabuhstudio/shared": "file:../shared",
        "@tailwindcss/vite": "^4.3.1",
        "@typescript-eslint/parser": "^8.48.1",
        "classnames": "^2.5.1",
        "glob": "^11.0.3",
        "less-loader": "^12.3.0",
        "prettier": "^3.7.4",
        "prettier-eslint": "^1.0.1",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-icons": "^5.5.0",
        "react-svg": "^16.3.0",
        "rsuite": "^6.0.0",
        "tailwindcss": "^4.3.1",
        "tone": "^15.1.22",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.33.0",
        "@types/node": "^25.5.0",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^5.0.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.3.0",
        "less": "^4.4.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.39.1",
        "vite": "^8.0.16",
        "vite-plugin-svgr": "^4.5.0"
    }
