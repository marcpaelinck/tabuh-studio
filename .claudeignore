# Block Node modules at all levels
node_modules/
backend/node_modules/
frontend/node_modules/

# Block compiled JavaScript and distribution builds
backend/dist/
frontend/dist/
frontend/.vite/

# Block heavy static assets (Audio, Fonts, Images)
**/sounds/
**/fonts/
**/icons/
**/svg/
frontend/public/

# Block duplicate/backup folders
**/scores copy/
**/unused/
**/tmp/
**/nocommit/